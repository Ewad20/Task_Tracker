{
  "Consul": {
    "ConsulAddress": "http://consul:8500",
    "ServiceName": "gateway",
    "ServiceId": "gateway-1",
    "ServiceAddress": "http://gateway:8080"
  },
  "ReverseProxy": {
    "Routes": {
      "users": {
        "ClusterId": "users",
        "Match": { "Path": "/api/users/{**catch-all}" }
      },
      "projects": {
        "ClusterId": "projects",
        "Match": { "Path": "/api/projects/{**catch-all}" }
      },
      "tasks": {
        "ClusterId": "tasks",
        "Match": { "Path": "/api/tasks/{**catch-all}" }
      },
      "notifications": {
        "ClusterId": "notifications",
        "Match": { "Path": "/api/notifications/{**catch-all}" }
      },
      "notificationHub": {
        "ClusterId": "notifications",
        "Match": { "Path": "/hubs/notifications/{**catch-all}" }
      },
      "audit": {
        "ClusterId": "audit",
        "Match": { "Path": "/api/audit/{**catch-all}" }
      },
      "reports": {
        "ClusterId": "reports",
        "Match": { "Path": "/api/reports/{**catch-all}" }
      }
    },
    "Clusters": {
      "users": { "Destinations": { "d1": { "Address": "http://userservice:8080/" } } },
      "projects": { "Destinations": { "d1": { "Address": "http://projectservice:8080/" } } },
      "tasks": { "Destinations": { "d1": { "Address": "http://taskservice:8080/" } } },
      "notifications": { "Destinations": { "d1": { "Address": "http://notificationservice:8080/" } } },
      "audit": { "Destinations": { "d1": { "Address": "http://auditservice:8080/" } } },
      "reports": { "Destinations": { "d1": { "Address": "http://reportingservice:8080/" } } }
    }
  }
}
